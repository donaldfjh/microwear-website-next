  "mediumIssues": [
    {
      "issue": "移动端触摸元素过小",
      "details": "14 个可点击元素小于 44x44 像素（Google 移动端可访问性标准）",
      "affectedElements": ["导航链接", "页脚链接", "小按钮"],
      "impact": "可能影响移动端用户体验和 Google 移动端友好度评分",
      "fix": "增加 CSS padding 或 min-width/min-height，确保所有可点击区域至少 44x44 像素"
    },
    {
      "issue": "sitemap.xml 更新频率",
      "details": "sitemap.xml 最后更新时间为 2026-03-21，距今约 12 天",
      "impact": "如有新内容发布，可能延迟搜索引擎收录",
      "fix": "确认 next-sitemap 是否在每次部署后自动运行，或设置定时任务每日更新"
    }
  ],
  "suggestions": [
    {
      "suggestion": "添加 CDN preconnect",
      "details": "如果使用外部 CDN 或字体服务，添加 <link rel=\"preconnect\"> 可加速资源加载",
      "example": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" crossorigin>"
    },
    {
      "suggestion": "添加结构化数据 (Schema.org)",
      "details": "为产品页面添加 Product schema，为博客文章添加 Article schema",
      "impact": "可在搜索结果中显示丰富摘要（价格、评分、作者等）"
    },
    {
      "suggestion": "考虑添加面包屑导航结构化数据",
      "details": "使用 BreadcrumbList schema 帮助搜索引擎理解网站结构",
      "impact": "可能在搜索结果中显示面包屑路径"
    }
  ],
